# ---------------------------------------------------------------------------
# Environment contract. Copy to `.env.local` and fill in real values.
# `.env*` is gitignored — never commit real credentials.
# ---------------------------------------------------------------------------

# Supabase project URL. Safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (publishable) key. Safe to expose — every query it makes is RLS-bound.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public origin this deployment is reached on, no trailing slash.
#
# This is what magic links are told to come back to. Supabase checks it against
# the project's redirect allow-list (Dashboard -> Authentication -> URL
# Configuration) and, on a miss, silently redirects to the project Site URL
# instead of erroring — the link still works, it just lands somewhere that
# cannot exchange it. So this value and the allow-list entry must agree exactly.
#
# Leave unset for local work and the request's Host header is used. When testing
# from a phone that Host is a LAN address or a tunnel URL, which is almost never
# allow-listed — set it explicitly and add the same value to the dashboard.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Service-role key. Bypasses RLS. SERVER-ONLY.
# Must be a different secret from the anon key above, and must NEVER be given a
# NEXT_PUBLIC_ prefix — that would inline it into the client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend API key for transactional email. Only consulted when EMAIL_DRY_RUN=off.
RESEND_API_KEY=re_your_api_key

# Sender identity used for outbound transactional mail.
EMAIL_FROM="Hraj Fotbal <noreply@hrajfotbal.com>"

# Email delivery gate. Anything other than off/false/0/no means DRY RUN:
# payloads are logged, never sent. Unset also means dry run (fail-safe).
# Flip to `off` only at the Phase 30 cutover, once Resend DNS has verified.
EMAIL_DRY_RUN=on

# IBAN encoded into the Czech SPD 1.0 payment QR strings.
PAYMENT_IBAN=CZ0000000000000000000000

# Shared secret gating the Vercel Cron routes. Generate with `openssl rand -hex 32`.
CRON_SECRET=your-cron-secret
